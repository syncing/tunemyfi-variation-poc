import argparse
import asyncio
import json
import math
import random
import subprocess
import wave
import urllib.request
from pathlib import Path
from typing import Any

import edge_tts
from PIL import Image, ImageDraw, ImageFont

OLLAMA_URL = "http://localhost:11434/api/generate"




def resolve_web_root() -> Path:
    cwd = Path.cwd()
    if (cwd / "web" / "data").exists():
        return cwd / "web"
    return cwd


def call_ollama(model: str, prompt: str) -> str:
    payload = json.dumps(
        {
            "model": model,
            "prompt": prompt,
            "stream": False,
            "keep_alive": "10m",
            "options": {"temperature": 0.35, "num_ctx": 8192},
        }
    ).encode("utf-8")

    req = urllib.request.Request(
        OLLAMA_URL,
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    with urllib.request.urlopen(req, timeout=600) as res:
        data = json.loads(res.read().decode("utf-8"))
        return data.get("response", "").strip()


def unload_ollama_model(model: str):
    payload = json.dumps({"model": model, "keep_alive": 0}).encode("utf-8")
    req = urllib.request.Request(
        OLLAMA_URL,
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        urllib.request.urlopen(req, timeout=30).read()
    except Exception:
        pass


async def make_tts(text: str, out_path: Path):
    communicate = edge_tts.Communicate(
        text=text,
        voice="ko-KR-SunHiNeural",
        rate="+0%",
        volume="+0%",
    )
    await communicate.save(str(out_path))


def ffprobe_duration(path: Path) -> float:
    out = subprocess.check_output(
        [
            "ffprobe",
            "-v",
            "error",
            "-show_entries",
            "format=duration",
            "-of",
            "default=noprint_wrappers=1:nokey=1",
            str(path),
        ]
    )
    return float(out.decode("utf-8").strip())


def parse_resource_ids(value: str) -> list[str]:
    return [x.strip() for x in value.split(",") if x.strip()]


def load_assets(root: Path, product_slug: str, resource_ids: list[str]) -> list[dict]:
    all_assets = []

    for resource_id in resource_ids:
        manifest_path = (
            root
            / "data"
            / "product-assets"
            / product_slug
            / "resources"
            / resource_id
            / "manifest.json"
        )

        if not manifest_path.exists():
            raise FileNotFoundError(f"manifest not found: {manifest_path}")

        manifest = json.loads(manifest_path.read_text("utf-8"))

        for asset in manifest.get("assets", []):
            copied = dict(asset)
            copied["_resourceId"] = resource_id
            copied["_resourceName"] = manifest.get("resourceName", resource_id)
            all_assets.append(copied)

    return all_assets


def load_selected_public_paths(root: Path, product_slug: str) -> list[str]:
    selected_path = root / "data" / "product-assets" / product_slug / "selected-assets.json"

    if not selected_path.exists():
        return []

    data = json.loads(selected_path.read_text("utf-8"))
    return data.get("selectedPublicPaths", [])


def pick_assets(root: Path, product_slug: str, resource_ids: list[str], limit: int) -> list[dict]:
    all_assets = load_assets(root, product_slug, resource_ids)
    selected_paths = load_selected_public_paths(root, product_slug)

    if selected_paths:
        by_path = {asset["publicPath"]: asset for asset in all_assets}
        picked = [by_path[p] for p in selected_paths if p in by_path]
        return picked[:limit]

    assets_by_resource: dict[str, list[dict]] = {rid: [] for rid in resource_ids}

    for asset in all_assets:
        assets_by_resource.setdefault(asset["_resourceId"], []).append(asset)

    picked = []

    while len(picked) < limit:
        added = False

        for resource_id in resource_ids:
            bucket = assets_by_resource.get(resource_id, [])

            if bucket:
                picked.append(bucket.pop(0))
                added = True

                if len(picked) >= limit:
                    break

        if not added:
            break

    return picked


def read_verdict_text(path_text: str) -> str:
    if not path_text:
        return ""

    path = Path(path_text)

    if not path.exists():
        raise FileNotFoundError(f"verdict file not found: {path}")

    raw = path.read_text("utf-8")

    try:
        parsed = json.loads(raw)
        return json.dumps(parsed, ensure_ascii=False, indent=2)
    except Exception:
        return raw


def load_pronunciation_map(root: Path) -> dict:
    path = root / "scripts" / "config" / "tts_pronunciation_ko.json"

    if not path.exists():
        return {}

    return json.loads(path.read_text("utf-8"))


def apply_pronunciation(text: str, pronunciation_map: dict) -> str:
    value = str(text or "")
    for source, spoken in sorted(
        pronunciation_map.items(),
        key=lambda item: len(item[0]),
        reverse=True,
    ):
        value = value.replace(source, spoken)

    return value



def make_spoken_script(narration: str, pronunciation_map: dict) -> str:
    """TTS 발음용 스크립트에는 발음 사전만 적용합니다.

    숫자는 자동으로 원/투/쓰리처럼 바꾸지 않고 원문 그대로 둡니다.
    숫자 발음을 바꾸고 싶을 때는 Step 4의 발음 치환 사전에 직접 등록하거나
    Spoken Script에서 직접 수정합니다.
    """
    return apply_pronunciation(narration, pronunciation_map)


def pronunciation_guide_text(pronunciation_map: dict) -> str:
    if not pronunciation_map:
        return ""

    lines = [
        f"- {source} → {spoken}"
        for source, spoken in sorted(
            pronunciation_map.items(),
            key=lambda item: len(item[0]),
            reverse=True,
        )
    ]

    return "\n".join(lines)


def build_prompt(
    product_name: str,
    target_seconds: int,
    verdict_text: str,
    resource_ids: list[str],
    asset_count: int,
    pronunciation_map: dict,
) -> str:
    if not verdict_text.strip():
        verdict_text = """
현재는 테스트 단계입니다.
수집된 제품 이미지와 기본 제품 정보를 바탕으로, 실제 사용자 의견을 종합한 리뷰 영상처럼 들리는
약 4~5분 분량의 한국어 리뷰 나레이션을 작성해 주세요.
"""

    guide = pronunciation_guide_text(pronunciation_map)

    guide_block = ""
    if guide:
        guide_block = f"""

발음 스크립트 변환 가이드:
아래 치환은 나중에 TTS 발음용 스크립트에만 자동 적용됩니다.
숫자는 자동 변환하지 않으며, 필요하면 Spoken Script에서 직접 수정합니다.

{guide}
"""

    return f"""
당신은 한국어 IT/오디오 리뷰 유튜브 채널의 나레이션 작가입니다.

제품명:
{product_name}

사용 이미지 리소스:
{", ".join(resource_ids)}

사용 이미지 수:
{asset_count}

아래 리뷰 종합 내용을 바탕으로 약 {target_seconds}초 분량의 한국어 나레이션 스크립트를 작성하세요.

조건:
- 자연스러운 존댓말
- 실제 사람이 말하는 유튜브 리뷰 톤
- 과장 광고처럼 쓰지 말 것
- 단점은 반드시 솔직하게 언급하되, 전체 인상은 제품의 장점, 만족 포인트, 구매 매력이 더 선명하게 남도록 구성할 것
- 장점은 구체적인 사용 장면과 함께 충분히 설명하고, 단점은 구매 전 확인 포인트처럼 차분하고 짧게 정리할 것
- 장점과 단점의 분량 비율은 대략 장점 75%, 단점 25% 정도로 둘 것
- 기존 모델 사용자와 신규 구매자 조언을 구분할 것
- 마크다운, 제목, 번호, 괄호 설명 없이 나레이션 본문만 출력할 것
- 화면 텍스트로도 활용될 수 있으므로 아라비아 숫자는 필요한 경우 그대로 써도 됨
- 너무 짧게 쓰지 말고 실제 {target_seconds}초 정도 말할 수 있는 분량으로 작성할 것
- 제품 이미지만 보고 단정하지 말고, 반드시 리뷰 종합 내용에 근거한 표현을 사용할 것
- 커뮤니티 평점, 별점, 점수, 몇 점짜리 제품 같은 평가 점수 표현은 절대 쓰지 말 것

리뷰 종합 내용:
{verdict_text}
{guide_block}
""".strip()


def build_shorts_prompt(
    product_name: str,
    target_seconds: int,
    verdict_text: str,
    resource_ids: list[str],
    asset_count: int,
    pronunciation_map: dict,
) -> str:
    if not verdict_text.strip():
        verdict_text = """
현재는 테스트 단계입니다.
수집된 제품 이미지와 기본 제품 정보를 바탕으로, 1분 미만 유튜브 쇼츠처럼 짧고 임팩트 있는
한국어 리뷰 나레이션을 작성해 주세요.
"""

    guide = pronunciation_guide_text(pronunciation_map)
    guide_block = ""
    if guide:
        guide_block = f"""

발음 스크립트 변환 가이드:
아래 치환은 나중에 TTS 발음용 스크립트에만 자동 적용됩니다.
숫자는 자동 변환하지 않으며, 필요하면 Spoken Script에서 직접 수정합니다.

{guide}
"""

    return f"""
당신은 한국어 IT/오디오 리뷰 유튜브 쇼츠 작가입니다.

제품명:
{product_name}

사용 이미지 리소스:
{", ".join(resource_ids)}

사용 이미지 수:
{asset_count}

아래 리뷰 종합 내용을 바탕으로 {target_seconds}초 안쪽, 반드시 1분 미만으로 끝나는 한국어 쇼츠 나레이션 스크립트를 작성하세요.

조건:
- 첫 문장은 바로 시선을 끄는 훅으로 시작할 것
- 전체 톤은 긍정적이고 구매 매력이 강하게 느껴지게 할 것
- 장점과 단점의 비율은 장점 85%, 단점 15% 정도로 둘 것
- 단점은 숨기지 말되, 아주 짧게 구매 전 확인 포인트로만 처리할 것
- 빠른 호흡의 쇼츠 나레이션처럼 문장을 짧고 선명하게 쓸 것
- 1분 미만 TTS에 맞게 너무 길게 쓰지 말 것
- 마크다운, 제목, 번호, 괄호 설명 없이 나레이션 본문만 출력할 것
- 제품 이미지만 보고 단정하지 말고, 반드시 리뷰 종합 내용에 근거한 표현을 사용할 것
- 커뮤니티 평점, 별점, 점수, 몇 점짜리 제품 같은 평가 점수 표현은 절대 쓰지 말 것

리뷰 종합 내용:
{verdict_text}
{guide_block}
""".strip()


def extract_json_object(text: str) -> dict:
    cleaned = text.strip()
    if cleaned.startswith("```"):
        cleaned = cleaned.strip("`")
        if cleaned.lower().startswith("json"):
            cleaned = cleaned[4:].strip()

    start = cleaned.find("{")
    end = cleaned.rfind("}")
    if start == -1 or end == -1 or end <= start:
        raise ValueError("JSON object not found in LLM response")

    return json.loads(cleaned[start : end + 1])


def shorten(text: Any, limit: int) -> str:
    value = str(text or "").strip().replace("\n", " ")
    value = " ".join(value.split())
    if len(value) <= limit:
        return value
    return value[: limit - 1].rstrip() + "…"


def build_overlay_prompt(
    product_name: str,
    verdict_text: str,
    narration_text: str,
    scene_count: int,
) -> str:
    return f"""
당신은 제품 리뷰 영상의 화면 자막 편집자입니다.

제품명:
{product_name}

리뷰 종합 내용:
{verdict_text}

나레이션 원문:
{narration_text}

아래 JSON만 출력하세요. 설명, 마크다운, 코드블록은 출력하지 마세요.

조건:
- sceneCaptions는 정확히 {scene_count}개에 가깝게 작성
- 나레이션 원문을 앞에서 뒤로 순서대로 {scene_count}개 구간으로 나눠, 각 구간의 내용과 카드가 대응되게 작성
- narrationSegment에는 해당 카드가 대응하는 나레이션 핵심 구절을 1문장으로 짧게 요약
- durationWeight는 해당 구간의 나레이션 길이에 맞춰 1~5 사이 숫자로 지정. 짧은 구간은 1~2, 긴 설명 구간은 4~5
- 각 title은 10~20자 정도의 짧은 제목
- 각 lines는 정확히 2개로 작성
- 각 줄은 단어 나열이나 짧은 구호가 아니라 자연스러운 완성형 문장으로 작성
- 각 줄은 28~42자 정도로, 간결하지만 정보가 충분하게 느껴지도록 작성
- 두 줄만 읽어도 해당 나레이션 구간의 핵심 판단 근거가 이해되게 작성
- 화면 카드 텍스트에는 숫자를 아라비아 숫자로 그대로 표시할 것. 예: 1, 2, 3, 32B
- 과장 광고처럼 쓰지 말 것
- 리뷰 종합 내용과 나레이션에 근거한 내용만 쓸 것
- 커뮤니티 평점, 별점, 점수, 몇 점짜리 제품 같은 평가 점수 표현은 카드와 summary에 절대 쓰지 말 것
- 장면별 카드도 단점을 숨기지는 않되, 제품의 강점과 매력이 먼저 보이도록 작성
- 마지막 summary는 장점 3개, 단점 2개, 한줄평 1개로 작성
- 한줄평은 긍정적 추천 톤을 기본으로 하되, 조건부 주의점은 짧게 포함

출력 형식:
{{
  "sceneCaptions": [
    {{
      "title": "착용감",
      "narrationSegment": "착용감과 안정감에 대한 나레이션 구간",
      "durationWeight": 3,
      "lines": ["장시간 착용해도 부담이 적다는 평가가 꾸준히 나옵니다.", "전작보다 밀착감과 안정감이 좋아졌다는 의견이 많습니다."]
    }}
  ],
  "summary": {{
    "pros": ["장점1", "장점2", "장점3"],
    "cons": ["단점1", "단점2", "단점3"],
    "oneLine": "한줄평"
  }}
}}
""".strip()


def normalize_overlay_plan(plan: dict, scene_count: int) -> dict:
    raw_captions = plan.get("sceneCaptions") if isinstance(plan, dict) else []
    if not isinstance(raw_captions, list):
        raw_captions = []

    captions = []
    for item in raw_captions[:scene_count]:
        if not isinstance(item, dict):
            continue
        lines = item.get("lines", [])
        if isinstance(lines, str):
            lines = [lines]
        if not isinstance(lines, list):
            lines = []

        try:
            duration_weight = float(item.get("durationWeight", item.get("duration_weight", 3)))
        except Exception:
            duration_weight = 3.0
        duration_weight = max(1.0, min(5.0, duration_weight))

        captions.append(
            {
                "title": shorten(item.get("title", "핵심 포인트"), 22),
                "narrationSegment": shorten(item.get("narrationSegment", item.get("narration_segment", "")), 120),
                "durationWeight": duration_weight,
                "lines": [shorten(x, 82) for x in lines[:2] if str(x).strip()],
            }
        )

    while len(captions) < scene_count:
        captions.append(
            {
                "title": "핵심 포인트",
                "narrationSegment": "리뷰 전반의 핵심 평가를 정리하는 구간",
                "durationWeight": 3.0,
                "lines": ["실제 사용자 의견에서 반복적으로 언급된 부분을 정리했습니다.", "구매 전 확인하면 좋은 포인트를 간결하게 압축했습니다."],
            }
        )

    raw_summary = plan.get("summary", {}) if isinstance(plan, dict) else {}
    if not isinstance(raw_summary, dict):
        raw_summary = {}

    def normalize_list(value: Any, fallback: str) -> list[str]:
        if isinstance(value, str):
            items = [value]
        elif isinstance(value, list):
            items = value
        else:
            items = []
        cleaned = [shorten(x, 64) for x in items[:3] if str(x).strip()]
        return cleaned or [fallback]

    summary = {
        "pros": normalize_list(raw_summary.get("pros"), "핵심 장점이 확인됩니다."),
        "cons": normalize_list(raw_summary.get("cons"), "구매 전 확인할 부분이 있습니다."),
        "oneLine": shorten(
            raw_summary.get("oneLine", "리뷰를 종합해 용도에 맞게 판단할 제품입니다."),
            110,
        ),
    }

    return {"sceneCaptions": captions, "summary": summary}


def generate_overlay_plan(
    model: str,
    product_name: str,
    verdict_text: str,
    narration_text: str,
    scene_count: int,
) -> dict:
    prompt = build_overlay_prompt(
        product_name=product_name,
        verdict_text=verdict_text,
        narration_text=narration_text,
        scene_count=scene_count,
    )

    try:
        raw = call_ollama(model, prompt)
        return normalize_overlay_plan(extract_json_object(raw), scene_count)
    except Exception:
        return normalize_overlay_plan(
            {
                "sceneCaptions": [
                    {
                        "title": "핵심 포인트",
                        "lines": ["주요 리뷰에서 공통적으로 드러난 평가를 영상에 맞춰 정리했습니다.", "구매 전에 확인하면 좋은 핵심 포인트를 두 줄로 압축했습니다."],
                    }
                    for _ in range(scene_count)
                ],
                "summary": {
                    "pros": ["전반적인 장점이 확인됩니다."],
                    "cons": ["일부 단점도 함께 언급됩니다."],
                    "oneLine": "리뷰 내용을 종합해 신중히 판단할 만한 제품입니다.",
                },
            },
            scene_count,
        )


def find_first_existing_font(candidates: list[str]) -> str | None:
    for path_text in candidates:
        if Path(path_text).exists():
            return path_text
    return None


def find_font_paths() -> dict[str, str]:
    """방송 자막 느낌에 가까운 굵은 산세리프 한글 폰트를 우선 사용합니다.

    외부 폰트 파일을 포함하지 않고, Ubuntu 서버에 설치된 Noto/Nanum 계열만 탐색합니다.
    fonts-noto-cjk가 있으면 Noto Sans CJK Bold/Regular를 우선 사용하고,
    없으면 NanumSquare/NanumBarunGothic 계열로 폴백합니다.
    """
    title_candidates = [
        # 최근 유튜브/쇼츠 자막에 많이 어울리는 모던 산세리프 계열을 우선 탐색합니다.
        "/usr/share/fonts/truetype/pretendard/Pretendard-ExtraBold.ttf",
        "/usr/share/fonts/truetype/pretendard/Pretendard-Bold.ttf",
        "/usr/share/fonts/truetype/pretendard/Pretendard-SemiBold.ttf",
        "/usr/share/fonts/truetype/inter/Inter-Bold.ttf",
        "/usr/share/fonts/truetype/inter/Inter-SemiBold.ttf",
        "/usr/share/fonts/opentype/noto/NotoSansCJK-Bold.ttc",
        "/usr/share/fonts/opentype/noto/NotoSansCJKkr-Bold.otf",
        "/usr/share/fonts/truetype/noto/NotoSansCJK-Bold.ttc",
        "/usr/share/fonts/truetype/nanum/NanumSquareB.ttf",
        "/usr/share/fonts/truetype/nanum/NanumBarunGothicBold.ttf",
        "/usr/share/fonts/truetype/nanum/NanumGothicBold.ttf",
    ]
    body_candidates = [
        "/usr/share/fonts/truetype/pretendard/Pretendard-Medium.ttf",
        "/usr/share/fonts/truetype/pretendard/Pretendard-Regular.ttf",
        "/usr/share/fonts/truetype/inter/Inter-Regular.ttf",
        "/usr/share/fonts/truetype/inter/Inter-Medium.ttf",
        "/usr/share/fonts/opentype/noto/NotoSansCJK-Medium.ttc",
        "/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc",
        "/usr/share/fonts/opentype/noto/NotoSansCJKkr-Regular.otf",
        "/usr/share/fonts/truetype/noto/NotoSansCJK-Regular.ttc",
        "/usr/share/fonts/truetype/nanum/NanumSquareR.ttf",
        "/usr/share/fonts/truetype/nanum/NanumBarunGothic.ttf",
        "/usr/share/fonts/truetype/nanum/NanumGothic.ttf",
    ]

    title_font = find_first_existing_font(title_candidates)
    body_font = find_first_existing_font(body_candidates)

    fallback = title_font or body_font or "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"
    if not Path(fallback).exists():
        raise FileNotFoundError(
            "한글 카드 렌더링용 폰트를 찾을 수 없습니다. fonts-noto-cjk 또는 fonts-nanum을 설치하세요."
        )

    return {
        "title": title_font or fallback,
        "body": body_font or fallback,
        "section": title_font or fallback,
    }


def find_font_path() -> str:
    # 기존 호출 호환용. 새 카드 렌더링은 find_font_paths()를 사용합니다.
    return find_font_paths()["body"]


def load_font(font_path: str, size: int):
    try:
        return ImageFont.truetype(font_path, size)
    except Exception:
        return ImageFont.load_default()


def clean_card_line(text: Any) -> str:
    value = str(text or "").strip()
    for prefix in ("✓", "✔", "☑", "•", "-"):
        if value.startswith(prefix):
            value = value[len(prefix):].strip()
    return value


def text_size(draw: ImageDraw.ImageDraw, text: str, font: ImageFont.ImageFont) -> tuple[int, int]:
    if not text:
        return 0, 0
    bbox = draw.textbbox((0, 0), text, font=font)
    return bbox[2] - bbox[0], bbox[3] - bbox[1]


def wrap_text_to_width(
    draw: ImageDraw.ImageDraw,
    text: str,
    font: ImageFont.ImageFont,
    max_width: int,
) -> list[str]:
    text = " ".join(str(text or "").split())
    if not text:
        return []

    lines: list[str] = []
    current = ""

    for token in text.split(" "):
        candidate = token if not current else f"{current} {token}"
        width, _ = text_size(draw, candidate, font)
        if width <= max_width:
            current = candidate
            continue

        if current:
            lines.append(current)
            current = token

        while text_size(draw, current, font)[0] > max_width and len(current) > 1:
            cut = len(current)
            while cut > 1 and text_size(draw, current[:cut], font)[0] > max_width:
                cut -= 1
            lines.append(current[:cut])
            current = current[cut:]

    if current:
        lines.append(current)

    return lines


def fit_text_block(
    draw: ImageDraw.ImageDraw,
    paragraphs: list[str],
    font_path: str,
    start_size: int,
    min_size: int,
    max_width: int,
    max_lines: int,
) -> tuple[ImageFont.ImageFont, list[str]]:
    for size in range(start_size, min_size - 1, -2):
        font = load_font(font_path, size)
        lines: list[str] = []
        for paragraph in paragraphs:
            lines.extend(wrap_text_to_width(draw, paragraph, font, max_width))
        if len(lines) <= max_lines:
            return font, lines

    font = load_font(font_path, min_size)
    lines = []
    for paragraph in paragraphs:
        lines.extend(wrap_text_to_width(draw, paragraph, font, max_width))
    return font, lines[:max_lines]


def draw_centered_lines(
    draw: ImageDraw.ImageDraw,
    lines: list[str],
    font: ImageFont.ImageFont,
    x_center: int,
    y: int,
    fill: tuple[int, int, int, int],
    line_gap: int,
):
    cursor_y = y
    for line in lines:
        width, height = text_size(draw, line, font)
        draw.text((x_center - width / 2, cursor_y), line, font=font, fill=fill)
        cursor_y += height + line_gap


def split_check_line(line: str) -> tuple[str, str]:
    value = str(line or "").strip()
    for mark in ("✓", "✔", "☑"):
        if value.startswith(mark):
            return mark, value[len(mark):].strip()
    return "", value


def draw_centered_check_lines(
    draw: ImageDraw.ImageDraw,
    lines: list[str],
    font: ImageFont.ImageFont,
    x_center: int,
    y: int,
    fill: tuple[int, int, int, int],
    line_gap: int,
    check_fill: tuple[int, int, int, int] = (14, 110, 70, 255),
):
    """Draw centered body lines while keeping the check mark visually aligned.

    A plain centered string like "✓ text" often looks slightly off because the
    check glyph has a different visual height/baseline from Korean text. This
    draws the check and the body text separately, then centers the combined
    group as one unit.
    """
    cursor_y = y
    gap = max(12, int(font.size * 0.38)) if hasattr(font, "size") else 14
    check_font = font

    for line in lines:
        mark, body = split_check_line(line)
        if not body:
            _, height = text_size(draw, line, font)
            cursor_y += height + line_gap
            continue

        body_w, body_h = text_size(draw, body, font)
        mark_w, mark_h = text_size(draw, mark, check_font) if mark else (0, 0)
        total_w = body_w + (gap + mark_w if mark else 0)
        x = x_center - total_w / 2

        if mark:
            # Small optical correction: move the check slightly down so its
            # visual center aligns with the Korean body text center.
            mark_y = cursor_y + max(0, (body_h - mark_h) / 2) + 2
            draw.text((x, mark_y), mark, font=check_font, fill=check_fill)
            x += mark_w + gap

        draw.text((x, cursor_y), body, font=font, fill=fill)
        cursor_y += body_h + line_gap



def render_caption_card_png(
    out_path: Path,
    overlay: dict,
    font_paths: dict[str, str],
    width: int = 1920,
    height: int = 1080,
):
    """Premium glass caption card with safer padding and no overflow."""
    canvas = Image.new("RGBA", (width, height), (0, 0, 0, 0))
    draw = ImageDraw.Draw(canvas)
    is_shorts = height > width

    title = str(overlay.get("title", "")).strip()
    raw_lines = overlay.get("lines", [])
    if isinstance(raw_lines, str):
        raw_lines = [raw_lines]
    body_paragraphs = [clean_card_line(x) for x in raw_lines if str(x).strip()]
    body_paragraphs = body_paragraphs[:3 if is_shorts else 2]

    gradient_top = int(height * (0.42 if is_shorts else 0.54))
    for y in range(gradient_top, height):
        ratio = (y - gradient_top) / max(1, height - gradient_top)
        alpha = int((106 if is_shorts else 86) * ratio * ratio)
        draw.line([(0, y), (width, y)], fill=(0, 0, 0, alpha))

    card_w = int(width * (0.84 if is_shorts else 0.64))
    card_w = min(card_w, int(width * 0.90))
    card_x = (width - card_w) // 2
    side_pad = int(width * (0.074 if is_shorts else 0.052))
    text_max_width = card_w - side_pad * 2

    max_lines = 3 if is_shorts else 2
    title_size = 50 if is_shorts else 48
    body_start = 36 if is_shorts else 33
    body_min = 25 if is_shorts else 23
    title_font = load_font(font_paths["title"], title_size)

    body_font, body_lines = fit_text_block(
        draw=draw,
        paragraphs=body_paragraphs,
        font_path=font_paths["body"],
        start_size=body_start,
        min_size=body_min,
        max_width=text_max_width,
        max_lines=max_lines,
    )
    title_lines = wrap_text_to_width(draw, title, title_font, text_max_width)[:1] if title else []

    title_h = text_size(draw, title_lines[0], title_font)[1] if title_lines else 0
    body_heights = [text_size(draw, line, body_font)[1] for line in body_lines]
    body_line_gap = 32 if is_shorts else 30
    title_body_gap = 56 if title_lines and body_lines else 0
    body_block_h = sum(body_heights) + max(0, len(body_lines) - 1) * body_line_gap
    total_text_h = title_h + title_body_gap + body_block_h

    pad_y = 72 if is_shorts else 62
    min_h = 315 if is_shorts else 260
    max_h = int(height * 0.34)
    card_h = max(min_h, min(max_h, total_text_h + pad_y * 2))

    available_text_h = card_h - pad_y * 2
    if total_text_h > available_text_h:
        body_font, body_lines = fit_text_block(
            draw=draw,
            paragraphs=body_paragraphs,
            font_path=font_paths["body"],
            start_size=max(body_min, body_start - 4),
            min_size=body_min,
            max_width=text_max_width,
            max_lines=max_lines,
        )
        body_heights = [text_size(draw, line, body_font)[1] for line in body_lines]
        body_block_h = sum(body_heights) + max(0, len(body_lines) - 1) * body_line_gap
        total_text_h = title_h + title_body_gap + body_block_h

    if is_shorts:
        card_y = int(height * 0.57)
        card_y = min(card_y, height - card_h - 230)
        card_y = max(220, card_y)
        radius = 30
    else:
        card_y = height - card_h - 72
        radius = 34

    x_center = width // 2
    shadow_offset = 18 if is_shorts else 15

    draw.rounded_rectangle(
        [card_x, card_y + shadow_offset, card_x + card_w, card_y + card_h + shadow_offset],
        radius=radius,
        fill=(0, 0, 0, 86),
    )
    draw.rounded_rectangle(
        [card_x, card_y, card_x + card_w, card_y + card_h],
        radius=radius,
        fill=(18, 20, 26, 194),
        outline=(255, 255, 255, 52),
        width=2,
    )
    draw.rounded_rectangle(
        [card_x + 24, card_y + 20, card_x + card_w - 24, card_y + 22],
        radius=2,
        fill=(255, 255, 255, 52),
    )
    accent_w = min(int(card_w * 0.28), 260)
    draw.rounded_rectangle(
        [x_center - accent_w // 2, card_y + card_h - 24,
         x_center + accent_w // 2, card_y + card_h - 18],
        radius=4,
        fill=(255, 210, 92, 176),
    )

    start_y = card_y + max(42 if is_shorts else 38, (card_h - total_text_h) // 2)
    if title_lines:
        draw_centered_lines(draw, title_lines, title_font, x_center, start_y, (255, 255, 255, 246), 0)
        start_y += title_h + title_body_gap

    draw_centered_lines(
        draw,
        body_lines,
        body_font,
        x_center,
        start_y,
        (238, 241, 247, 238),
        body_line_gap,
    )

    canvas.save(out_path)


def render_summary_card_png(
    out_path: Path,
    summary: dict,
    font_paths: dict[str, str],
    width: int = 1920,
    height: int = 1080,
):
    """Premium compact summary card. Fits text inside the box."""
    canvas = Image.new("RGBA", (width, height), (0, 0, 0, 0))
    draw = ImageDraw.Draw(canvas)
    is_shorts = height > width

    gradient_top = int(height * (0.36 if is_shorts else 0.44))
    for y in range(gradient_top, height):
        ratio = (y - gradient_top) / max(1, height - gradient_top)
        alpha = int((122 if is_shorts else 100) * ratio * ratio)
        draw.line([(0, y), (width, y)], fill=(0, 0, 0, alpha))

    pros = [str(x).strip() for x in summary.get("pros", []) if str(x).strip()]
    cons = [str(x).strip() for x in summary.get("cons", []) if str(x).strip()]
    one_line = str(summary.get("oneLine", "")).strip()

    sections_src = [
        ("장점", pros[:2]),
        ("단점", cons[:2]),
        ("한줄평", [one_line] if one_line else []),
    ]

    card_w = int(width * (0.84 if is_shorts else 0.60))
    card_x = (width - card_w) // 2
    text_max_width = int(card_w * (0.78 if is_shorts else 0.80))
    radius = 30 if is_shorts else 34

    max_card_h = int(height * 0.58)
    min_card_h = 500 if is_shorts else 410
    section_size = 42 if is_shorts else 38
    body_size = 31 if is_shorts else 28
    body_min = 23 if is_shorts else 22

    best = None
    while body_size >= body_min:
        section_font = load_font(font_paths["section"], section_size)
        body_font = load_font(font_paths["body"], body_size)
        one_line_font = load_font(font_paths["body"], body_size)

        label_body_gap = 52 if is_shorts else 46
        section_gap = 36 if is_shorts else 32
        line_gap = 16 if is_shorts else 14

        blocks = []
        total_text_h = 0

        for label, items in sections_src:
            wrapped = []
            font = one_line_font if label == "한줄평" else body_font
            for item in items:
                wrapped.extend(wrap_text_to_width(draw, clean_card_line(item), font, text_max_width)[:2])

            if not wrapped:
                continue

            label_h = text_size(draw, label, section_font)[1]
            line_h = text_size(draw, "가", font)[1]
            block_h = label_h + label_body_gap + len(wrapped) * line_h + max(0, len(wrapped) - 1) * line_gap
            total_text_h += block_h + (section_gap if blocks else 0)
            blocks.append((label, wrapped, font, label_h, line_h))

        pad_y = 64 if is_shorts else 58
        card_h = max(min_card_h, total_text_h + pad_y * 2)
        best = (blocks, section_font, pad_y, card_h, total_text_h, label_body_gap, section_gap, line_gap)

        if card_h <= max_card_h:
            break

        body_size -= 2
        section_size = max(32 if is_shorts else 30, section_size - 1)

    blocks, section_font, pad_y, card_h, total_text_h, label_body_gap, section_gap, line_gap = best
    card_h = min(card_h, max_card_h)

    card_y = int((height - card_h) / 2)
    if not is_shorts:
        card_y = min(card_y + 30, height - card_h - 72)

    x_center = width // 2
    shadow_offset = 18 if is_shorts else 15

    draw.rounded_rectangle(
        [card_x, card_y + shadow_offset, card_x + card_w, card_y + card_h + shadow_offset],
        radius=radius,
        fill=(0, 0, 0, 90),
    )
    draw.rounded_rectangle(
        [card_x, card_y, card_x + card_w, card_y + card_h],
        radius=radius,
        fill=(18, 20, 26, 198),
        outline=(255, 255, 255, 54),
        width=2,
    )
    draw.rounded_rectangle(
        [card_x + 24, card_y + 20, card_x + card_w - 24, card_y + 22],
        radius=2,
        fill=(255, 255, 255, 52),
    )
    accent_w = min(int(card_w * 0.28), 240)
    draw.rounded_rectangle(
        [x_center - accent_w // 2, card_y + card_h - 24,
         x_center + accent_w // 2, card_y + card_h - 18],
        radius=4,
        fill=(255, 210, 92, 176),
    )

    y = card_y + max(42 if is_shorts else 38, (card_h - total_text_h) // 2)

    for idx, (label, wrapped, font, label_h, line_h) in enumerate(blocks):
        if idx:
            y += section_gap

        draw_centered_lines(draw, [label], section_font, x_center, y, (255, 255, 255, 246), 0)
        y += label_h + label_body_gap

        draw_centered_lines(draw, wrapped, font, x_center, y, (238, 241, 247, 238), line_gap)
        y += len(wrapped) * line_h + max(0, len(wrapped) - 1) * line_gap

    canvas.save(out_path)

def render_watermark_png(
    out_path: Path,
    font_paths: dict[str, str],
    width: int = 1920,
    height: int = 1080,
):
    canvas = Image.new("RGBA", (width, height), (0, 0, 0, 0))
    draw = ImageDraw.Draw(canvas)

    big_font = load_font(font_paths["title"], 92)
    small_font = load_font(font_paths["body"], 30)

    # 중앙의 아주 연한 워터마크
    main_text = "TuneMyFi"
    w, h = text_size(draw, main_text, big_font)
    draw.text(
        ((width - w) / 2, height * 0.46 - h / 2),
        main_text,
        font=big_font,
        fill=(255, 255, 255, 22),
        stroke_width=1,
        stroke_fill=(0, 0, 0, 16),
    )

    # 우하단 박스형 워터마크는 제거했습니다.
    # 중앙의 아주 연한 TuneMyFi 워터마크만 남겨 영상 전체에 브랜드 식별감을 유지합니다.

    canvas.save(out_path)



def build_bgm_prompt(product_name: str, verdict_text: str, narration_text: str) -> str:
    return f"""
당신은 제품 리뷰 영상의 배경음악 디렉터입니다.
아래 내용을 보고 영상에 어울리는 밝고 경쾌한 BGM 분위기를 JSON으로만 정하세요.
음악은 실제 음원이 아니라 프로그램으로 생성되는 신스 패드, 벨, 가벼운 리듬 사운드입니다.

제품명:
{product_name}

리뷰 종합 내용:
{verdict_text[:5000]}

나레이션:
{narration_text[:5000]}

조건:
- 설명, 마크다운, 코드블록 없이 JSON만 출력
- mood는 bright, premium, calm, tech, warm 중 하나
- intensity는 1~5 사이. 기본은 밝고 경쾌한 리뷰 영상에 맞게 3 권장
- bpm은 84~124 사이
- key는 C, D, E, F, G, A 중 하나

출력 형식:
{{
  "mood": "bright",
  "intensity": 3,
  "bpm": 104,
  "key": "C",
  "description": "밝고 경쾌하게 변화하는 제품 리뷰용 BGM"
}}
""".strip()


def normalize_bgm_plan(plan: dict | None) -> dict:
    if not isinstance(plan, dict):
        plan = {}

    mood = str(plan.get("mood", "bright")).strip().lower()
    if mood not in {"premium", "calm", "bright", "tech", "warm"}:
        mood = "bright"

    try:
        intensity = int(plan.get("intensity", 3))
    except Exception:
        intensity = 3
    intensity = max(1, min(5, intensity))

    try:
        bpm = int(plan.get("bpm", 104))
    except Exception:
        bpm = 104
    bpm = max(84, min(124, bpm))

    key = str(plan.get("key", "C")).strip().upper()[:1]
    if key not in {"C", "D", "E", "F", "G", "A"}:
        key = "C"

    description = shorten(plan.get("description", "밝고 경쾌하게 변화하는 제품 리뷰용 배경음악"), 120)

    return {
        "mood": mood,
        "intensity": intensity,
        "bpm": bpm,
        "key": key,
        "generator": "algorithmic-open-composer",
        "arrangement": "A/B/A/C sections + chord progression + bass + bell lead + light rhythm",
        "description": description,
    }



def find_external_bgm_file(root: Path, is_shorts: bool = False) -> Path | None:
    """Use a user-provided royalty-free BGM file when present.

    파일을 직접 넣으면 생성형 BGM 대신 우선 사용합니다.
    권장 경로:
    - web/data/bgm/shorts.* 또는 web/public/bgm/shorts.*
    - web/data/bgm/default.* 또는 web/public/bgm/default.*
    지원 확장자: mp3, m4a, wav, flac, ogg
    """
    names = (["shorts", "default"] if is_shorts else ["default", "longform", "review"])
    exts = ["mp3", "m4a", "wav", "flac", "ogg"]
    dirs = [root / "data" / "bgm", root / "public" / "bgm"]
    for directory in dirs:
        for name in names:
            for ext in exts:
                candidate = directory / f"{name}.{ext}"
                if candidate.exists():
                    return candidate
    return None

def generate_bgm_plan(model: str, product_name: str, verdict_text: str, narration_text: str, bgm_mood: str = "bright") -> dict:
    if bgm_mood and bgm_mood != "auto":
        return normalize_bgm_plan({
            "mood": bgm_mood,
            "intensity": 3 if bgm_mood == "bright" else 2,
            "bpm": 106 if bgm_mood == "bright" else 92,
            "key": "C" if bgm_mood == "bright" else "A",
            "description": f"{bgm_mood} 분위기의 제품 리뷰용 BGM",
        })
    try:
        raw = call_ollama(model, build_bgm_prompt(product_name, verdict_text, narration_text))
        return normalize_bgm_plan(extract_json_object(raw))
    except Exception:
        return normalize_bgm_plan({
            "mood": "bright",
            "intensity": 3,
            "bpm": 104,
            "key": "C",
            "description": "밝고 경쾌하게 변화하는 제품 리뷰용 BGM",
        })


def midi_to_freq(midi: int) -> float:
    return 440.0 * (2.0 ** ((midi - 69) / 12.0))


def key_root_midi(key: str) -> int:
    return {"C": 48, "D": 50, "E": 52, "F": 53, "G": 55, "A": 57}.get(key.upper(), 57)


def bgm_chord_progression(root: int, mood: str) -> list[list[int]]:
    """조금 더 밝고 변화가 있는 8마디 진행을 만듭니다."""
    if mood == "bright":
        degrees = [0, 7, 9, 5, 0, 4, 5, 7]
        qualities = ["maj", "maj", "min", "maj", "maj7", "min", "maj", "sus"]
    elif mood == "warm":
        degrees = [0, 5, 9, 7, 4, 5, 0, 7]
        qualities = ["maj7", "maj", "min", "maj", "min", "maj", "maj7", "sus"]
    elif mood == "tech":
        degrees = [0, 3, 7, 10, 0, 5, 7, 10]
        qualities = ["min", "maj", "min", "maj", "min7", "maj", "min", "maj"]
    elif mood == "calm":
        degrees = [0, 5, 9, 7, 0, 5, 4, 7]
        qualities = ["maj7", "maj", "min", "maj7", "maj7", "maj", "min", "sus"]
    else:
        degrees = [0, 8, 3, 10, 0, 5, 3, 7]
        qualities = ["min", "maj", "maj", "maj", "min7", "maj", "maj", "sus"]

    chords: list[list[int]] = []
    for deg, q in zip(degrees, qualities):
        base = root + deg
        if q == "min":
            chords.append([base, base + 3, base + 7, base + 12])
        elif q == "min7":
            chords.append([base, base + 3, base + 7, base + 10])
        elif q == "maj7":
            chords.append([base, base + 4, base + 7, base + 11])
        elif q == "sus":
            chords.append([base, base + 5, base + 7, base + 12])
        else:
            chords.append([base, base + 4, base + 7, base + 12])
    return chords

def soft_clip(value: float) -> float:
    return math.tanh(value * 1.4) / 1.4


def generate_background_music_wav(out_path: Path, duration_seconds: float, plan: dict, volume: float = 0.12):
    """MIDI 시퀀서/오픈소스 생성기 느낌의 다채로운 BGM을 직접 합성합니다.

    외부 음원을 쓰지 않고, 16비트 WAV를 코드로 생성합니다. 단순 패드 반복이 아니라
    A/B/A/C 섹션, 코드 진행 변화, 베이스, 벨 리드, 가벼운 드럼/하이햇, 브리지 필을
    넣어 리뷰 영상용으로 밝고 계속 움직이는 배경음악을 만듭니다.
    """
    sample_rate = 44100
    duration_seconds = max(8.0, float(duration_seconds))
    total_samples = int(duration_seconds * sample_rate)
    mood = str(plan.get("mood", "bright"))
    bpm = int(plan.get("bpm", 108))
    intensity = int(plan.get("intensity", 3))
    root = key_root_midi(str(plan.get("key", "C")))
    base_chords = bgm_chord_progression(root, mood)

    rnd = random.Random(f"open-composer-{mood}-{bpm}-{root}-{duration_seconds:.1f}")
    phases = [rnd.random() * math.tau for _ in range(32)]
    beat = 60.0 / bpm
    bar = beat * 4
    section_bars = 8
    base_amp = max(0.03, min(0.28, volume)) * (0.72 + intensity * 0.12)

    major_scale = [0, 2, 4, 7, 9, 12, 14, 16]
    minor_scale = [0, 3, 5, 7, 10, 12, 15, 17]
    scale = minor_scale if mood in {"tech", "premium"} else major_scale

    def section_name(t: float) -> str:
        sec = int(t // (bar * section_bars)) % 4
        return ["A", "B", "A2", "C"][sec]

    def chord_for_time(t: float) -> list[int]:
        bar_index = int(t // bar)
        sec = section_name(t)
        chord = list(base_chords[bar_index % len(base_chords)])
        if sec == "B":
            chord = [n + (2 if i % 2 == 0 else 0) for i, n in enumerate(chord)]
        elif sec == "A2":
            chord = [n + (12 if i == len(chord) - 1 else 0) for i, n in enumerate(chord)]
        elif sec == "C":
            chord = [n + (5 if i >= 2 else 0) for i, n in enumerate(chord)]
        return chord

    def sine(freq: float, t: float, phase: float = 0.0) -> float:
        return math.sin(math.tau * freq * t + phase)

    def soft_square(freq: float, t: float, phase: float = 0.0) -> float:
        return math.tanh(2.4 * sine(freq, t, phase)) * 0.45

    def hit_env(pos: float, decay: float) -> float:
        if pos < 0:
            return 0.0
        return math.exp(-pos * decay)

    out_path.parent.mkdir(parents=True, exist_ok=True)

    with wave.open(str(out_path), "wb") as wav:
        wav.setnchannels(2)
        wav.setsampwidth(2)
        wav.setframerate(sample_rate)

        frames = bytearray()
        for n in range(total_samples):
            t = n / sample_rate
            chord = chord_for_time(t)
            sec = section_name(t)
            beat_pos = t % beat
            bar_pos = t % bar
            beat_index = int(t // beat)
            eighth_index = int(t // (beat / 2))
            phrase = int(t // (bar * 2))

            fade_in = min(1.0, t / 3.5)
            fade_out = min(1.0, max(0.0, (duration_seconds - t) / 5.0))
            env = fade_in * fade_out
            side_motion = 0.88 + 0.12 * math.sin(math.tau * 0.06 * t)

            # 따뜻한 패드. 섹션마다 최상단 음이 조금씩 바뀌며 단조로운 반복을 줄입니다.
            pad = 0.0
            for i, note in enumerate(chord):
                f = midi_to_freq(note)
                pad += sine(f, t, phases[i]) * 0.115
                pad += sine(f * 2.0, t, phases[i + 4]) * 0.028
            pad *= 0.72 + 0.10 * math.sin(math.tau * 0.03 * t)

            # 베이스는 마디마다 루트/5도/옥타브로 움직입니다.
            bass_pattern = [0, 7, 12, 7] if sec != "C" else [0, 12, 7, 5]
            bass_note = chord[0] - 12 + bass_pattern[int(bar_pos // beat) % 4]
            bass = soft_square(midi_to_freq(bass_note), t, phases[12]) * 0.105

            # 벨/플럭 리드. 8분음표 단위로 멜로디가 바뀌고 섹션마다 음역이 달라집니다.
            motif = [0, 2, 4, 2, 5, 4, 7, 9, 7, 5, 4, 2, 0, 4, 7, 12]
            motif_idx = (eighth_index + phrase * 3) % len(motif)
            lead_oct = 24 if sec in {"A", "A2"} else 36
            lead_note = root + lead_oct + scale[motif[motif_idx] % len(scale)]
            pluck_env = hit_env(t % (beat / 2), 13.0)
            bell = (
                sine(midi_to_freq(lead_note), t, phases[14]) * 0.075
                + sine(midi_to_freq(lead_note) * 2.01, t, phases[15]) * 0.030
            ) * pluck_env

            # 카운터 멜로디는 2마디마다 등장해 변화감을 줍니다.
            counter = 0.0
            if sec in {"B", "C"} or (phrase % 3 == 2):
                counter_note = chord[(beat_index // 2) % len(chord)] + 24
                counter_env = hit_env(t % beat, 5.5)
                counter = sine(midi_to_freq(counter_note), t, phases[16]) * 0.045 * counter_env

            # 가벼운 드럼/하이햇. 밝은 리뷰 느낌을 주되 나레이션을 방해하지 않도록 낮게 둡니다.
            kick = 0.0
            if int(bar_pos // beat) in (0, 2):
                kick = sine(55 + 25 * hit_env(beat_pos, 18), t, phases[18]) * 0.090 * hit_env(beat_pos, 10)
            snare_pos = abs(bar_pos - beat * 2)
            snare = 0.0
            if snare_pos < beat * 0.18:
                snare = sine(180, t, phases[19]) * 0.035 * hit_env(snare_pos, 18)
            hat_pos = t % (beat / 2)
            hat_gate = 1.0 if eighth_index % 2 == 0 else 0.62
            hat = (sine(7200, t, phases[20]) + sine(9100, t, phases[21])) * 0.012 * hat_gate * hit_env(hat_pos, 28)

            # 섹션 마지막에 아주 작은 필을 넣어 다음 장면으로 넘어가는 느낌을 만듭니다.
            fill = 0.0
            section_pos = t % (bar * section_bars)
            if section_pos > bar * section_bars - beat * 2:
                fill_env = hit_env(t % (beat / 4), 22)
                fill_note = root + 36 + scale[(int(t / (beat / 4)) + phrase) % len(scale)]
                fill = sine(midi_to_freq(fill_note), t, phases[22]) * 0.035 * fill_env

            shimmer = sine(midi_to_freq(chord[-1] + 12), t, phases[23]) * (0.014 + 0.010 * math.sin(math.tau * 0.09 * t))
            value = soft_clip((pad + bass + bell + counter + kick + snare + hat + fill + shimmer) * base_amp * env * side_motion)

            pan = 0.5 + 0.16 * math.sin(math.tau * 0.035 * t) + 0.04 * math.sin(math.tau * 0.11 * t)
            left = int(max(-1.0, min(1.0, value * (1.08 - pan))) * 32767)
            right = int(max(-1.0, min(1.0, value * (0.92 + pan))) * 32767)
            frames += int(left).to_bytes(2, "little", signed=True)
            frames += int(right).to_bytes(2, "little", signed=True)

            if len(frames) >= 131072:
                wav.writeframes(frames)
                frames.clear()

        if frames:
            wav.writeframes(frames)



VIDEO_TRANSITION_DURATION = 1.15

# 과한 wipe/cover 계열은 정지 이미지에서 튀어 보일 수 있어서,
# 자연스러운 방송 리포트 느낌의 부드러운 전환만 사용합니다.
TRANSITION_LIBRARY = [
    "fade",
    "dissolve",
    "smoothleft",
    "smoothright",
    "smoothup",
    "smoothdown",
]


def even(value: int) -> int:
    return int(value) if int(value) % 2 == 0 else int(value) + 1


def scene_motion_filter(scene_index: int, width: int, height: int, seconds: float, fps: int) -> str:
    """Generate a smooth Ken Burns-style motion without zoompan jitter.

    기존 zoompan은 정지 이미지에서 프레임 단위 좌표 반올림 때문에 미세하게
    드드드 움직이는 느낌이 날 수 있습니다. 여기서는 이미지를 살짝 크게 만든 뒤
    crop 창만 천천히 이동시켜 더 자연스럽게 보이도록 합니다.
    """
    duration = max(0.1, float(seconds))
    scale_w = even(int(width * 1.14))
    scale_h = even(int(height * 1.14))
    slack_x = "(iw-ow)"
    slack_y = "(ih-oh)"

    patterns = [
        # 아주 느린 좌→우 / 우→좌 팬
        (f"x='{slack_x}*0.18+{slack_x}*0.64*t/{duration:.3f}'", f"y='{slack_y}*0.50'"),
        (f"x='{slack_x}*0.82-{slack_x}*0.64*t/{duration:.3f}'", f"y='{slack_y}*0.50'"),
        # 아주 느린 상→하 / 하→상 팬
        (f"x='{slack_x}*0.50'", f"y='{slack_y}*0.18+{slack_y}*0.64*t/{duration:.3f}'"),
        (f"x='{slack_x}*0.50'", f"y='{slack_y}*0.82-{slack_y}*0.64*t/{duration:.3f}'"),
        # 중심을 기준으로 아주 작은 호흡감
        (f"x='{slack_x}*0.50+{slack_x}*0.10*sin(3.14159*t/{duration:.3f})'", f"y='{slack_y}*0.50'"),
        (f"x='{slack_x}*0.50'", f"y='{slack_y}*0.50+{slack_y}*0.10*sin(3.14159*t/{duration:.3f})'"),
    ]
    x_expr, y_expr = patterns[(scene_index - 1) % len(patterns)]
    return (
        f"fps={fps},"
        f"scale={scale_w}:{scale_h}:force_original_aspect_ratio=increase,"
        f"crop=w={width}:h={height}:{x_expr}:{y_expr},"
        "eq=contrast=1.055:saturation=1.085:brightness=0.004,"
        "unsharp=5:5:0.38:3:3:0.18,"
        "vignette=PI/7,"
        "setpts=PTS-STARTPTS"
    )


def render_video_with_transitions(
    clips: list[Path],
    durations: list[float],
    out_path: Path,
    fps: int = 30,
    transition_duration: float = VIDEO_TRANSITION_DURATION,
):
    if not clips:
        raise RuntimeError("전환할 클립이 없습니다.")

    if len(clips) == 1:
        subprocess.run([
            "ffmpeg", "-y", "-i", str(clips[0]),
            "-c:v", "libx264", "-preset", "medium", "-crf", "18", "-pix_fmt", "yuv420p", "-r", str(fps),
            str(out_path),
        ], check=True)
        return

    command = ["ffmpeg", "-y"]
    for clip in clips:
        command.extend(["-i", str(clip)])

    filter_parts = []
    previous = "[0:v]"
    cumulative = float(durations[0])

    for idx in range(1, len(clips)):
        trans = TRANSITION_LIBRARY[(idx - 1) % len(TRANSITION_LIBRARY)]
        offset = max(0.0, cumulative - transition_duration)
        out_label = f"[vx{idx}]" if idx < len(clips) - 1 else "[vout]"
        filter_parts.append(
            f"{previous}[{idx}:v]xfade=transition={trans}:duration={transition_duration:.2f}:offset={offset:.2f}{out_label}"
        )
        previous = out_label
        cumulative += float(durations[idx]) - transition_duration

    command.extend([
        "-filter_complex", ";".join(filter_parts),
        "-map", "[vout]",
        "-an",
        "-r", str(fps),
        "-pix_fmt", "yuv420p",
        "-c:v", "libx264",
        "-preset", "medium",
        "-crf", "18",
        str(out_path),
    ])
    subprocess.run(command, check=True)





def build_caption_timeline(captions: list[dict], total_seconds: float) -> list[dict]:
    """Build caption timings independent from image cuts."""
    clean: list[dict] = []

    for item in captions or []:
        if not isinstance(item, dict):
            continue

        title = str(item.get("title", "")).strip()
        lines = item.get("lines", [])

        if isinstance(lines, str):
            lines = [lines]

        lines = [str(x).strip() for x in lines if str(x).strip()]

        if title or lines:
            copied = dict(item)
            copied["title"] = title
            copied["lines"] = lines[:3]
            clean.append(copied)

    if not clean or total_seconds <= 0:
        return []

    weights = []
    for item in clean:
        try:
            w = float(item.get("durationWeight", 3.0))
        except Exception:
            w = 3.0
        weights.append(max(1.0, min(5.0, w)))

    total_weight = sum(weights) or float(len(clean))
    timeline: list[dict] = []
    cursor = 0.0

    for item, weight in zip(clean, weights):
        duration = max(2.8, total_seconds * weight / total_weight)

        if cursor + duration > total_seconds:
            duration = max(1.8, total_seconds - cursor)

        if duration <= 1.0:
            break

        entry = dict(item)
        entry["start"] = round(cursor, 3)
        entry["duration"] = round(duration, 3)
        entry["end"] = round(min(total_seconds, cursor + duration), 3)
        timeline.append(entry)

        cursor += duration

        if cursor >= total_seconds - 0.5:
            break

    if timeline:
        timeline[-1]["end"] = round(total_seconds, 3)
        timeline[-1]["duration"] = round(max(1.0, total_seconds - float(timeline[-1]["start"])), 3)

    return timeline


def overlay_caption_timeline(
    base_video_path: Path,
    out_path: Path,
    captions: list[dict],
    total_seconds: float,
    work_dir: Path,
    font_paths: dict[str, str],
    width: int = 1920,
    height: int = 1080,
    fps: int = 30,
) -> list[dict]:
    """Overlay caption cards on the already-transitioned video by narration time."""
    timeline = build_caption_timeline(captions, total_seconds)

    if not timeline:
        if base_video_path != out_path:
            subprocess.run(
                ["ffmpeg", "-y", "-i", str(base_video_path), "-c:v", "copy", "-an", str(out_path)],
                check=True,
            )
        return []

    command = ["ffmpeg", "-y", "-i", str(base_video_path)]

    for idx, item in enumerate(timeline, 1):
        card_path = work_dir / f"timeline_caption_{idx:02d}_{width}x{height}.png"
        render_caption_card_png(card_path, item, font_paths, width=width, height=height)
        command.extend(["-loop", "1", "-t", f"{total_seconds + 2.0:.3f}", "-i", str(card_path)])

    parts: list[str] = []
    prev = "[0:v]"

    for idx, item in enumerate(timeline, 1):
        start = float(item.get("start", 0.0))
        duration = float(item.get("duration", 2.0))
        end = float(item.get("end", start + duration))

        fade_in = min(0.35, max(0.12, duration * 0.18))
        fade_out = min(0.45, max(0.12, duration * 0.22))
        fade_out_start = max(0.0, duration - fade_out)

        card = f"[card{idx}]"
        out = f"[vt{idx}]" if idx < len(timeline) else "[vout]"

        parts.append(
            f"[{idx}:v]format=rgba,"
            f"fade=t=in:st=0:d={fade_in:.3f}:alpha=1,"
            f"fade=t=out:st={fade_out_start:.3f}:d={fade_out:.3f}:alpha=1,"
            f"setpts=PTS+{start:.3f}/TB{card}"
        )
        parts.append(
            f"{prev}{card}overlay=0:0:enable='between(t,{start:.3f},{end:.3f})'{out}"
        )
        prev = out

    command.extend([
        "-filter_complex", ";".join(parts),
        "-map", "[vout]",
        "-an",
        "-r", str(fps),
        "-pix_fmt", "yuv420p",
        "-c:v", "libx264",
        "-preset", "medium",
        "-crf", "18",
        str(out_path),
    ])

    subprocess.run(command, check=True)
    return timeline

def distribute_scene_durations(
    captions: list[dict],
    scene_count: int,
    target_total_seconds: float,
    min_seconds: float = 3.2,
    max_seconds: float = 8.5,
) -> list[float]:
    """카드별 durationWeight를 이용해 나레이션 길이에 맞는 장면 시간을 배분합니다.

    이미지 장면들의 xfade 겹침을 고려한 목표 총 길이에 맞춰 각 이미지 클립 길이를
    조정합니다. 카드가 나레이션 구간별로 생성되어 있으면 실제 표시 타이밍도
    나레이션 흐름에 더 가깝게 맞춰집니다.
    """
    if scene_count <= 0:
        return []

    weights: list[float] = []
    for i in range(scene_count):
        item = captions[min(i, len(captions) - 1)] if captions else {}
        try:
            weight = float(item.get("durationWeight", 3.0))
        except Exception:
            weight = 3.0
        weights.append(max(1.0, min(5.0, weight)))

    total_weight = sum(weights) or float(scene_count)
    raw = [target_total_seconds * weight / total_weight for weight in weights]

    # 목표 길이가 너무 짧으면 최소 길이를 자동으로 낮춰 전체 싱크가 밀리지 않게 합니다.
    if min_seconds * scene_count > target_total_seconds:
        min_seconds = max(1.8, target_total_seconds / scene_count * 0.82)

    durations = [max(min_seconds, min(max_seconds, value)) for value in raw]

    # clamp 이후 합계가 목표에서 벗어나면 비율 보정합니다.
    total = sum(durations) or target_total_seconds
    if total > 0:
        scale = target_total_seconds / total
        durations = [max(1.8, value * scale) for value in durations]

    return durations



def render_scene(
    image_path: Path,
    clip_path: Path,
    seconds: float,
    overlay: dict | None = None,
    work_dir: Path | None = None,
    scene_index: int = 1,
    width: int = 1920,
    height: int = 1080,
    fps: int = 30,
    font_paths: dict[str, str] | None = None,
):
    """Render image-only scene. Captions are overlaid later by narration timeline."""
    motion_filter = scene_motion_filter(scene_index, width, height, seconds, fps)
    filter_complex = f"[0:v]{motion_filter},format=rgba[base]"
    command = ["ffmpeg", "-y", "-loop", "1", "-i", str(image_path)]

    watermark_path = None
    if work_dir and font_paths:
        watermark_path = work_dir / f"watermark_tunemyfi_{width}x{height}.png"
        if not watermark_path.exists():
            render_watermark_png(watermark_path, font_paths, width=width, height=height)

    if watermark_path:
        command.extend(["-loop", "1", "-i", str(watermark_path)])
        filter_complex += ";[base][1:v]overlay=0:0:shortest=1,format=yuv420p[outv]"
    else:
        filter_complex += ";[base]format=yuv420p[outv]"

    command.extend([
        "-filter_complex", filter_complex,
        "-map", "[outv]",
        "-t", str(seconds),
        "-r", str(fps),
        "-an",
        str(clip_path),
    ])

    subprocess.run(command, check=True)

def render_summary_scene(
    image_path: Path,
    clip_path: Path,
    seconds: float,
    summary: dict,
    work_dir: Path,
    width: int = 1920,
    height: int = 1080,
    fps: int = 30,
    font_paths: dict[str, str] | None = None,
):
    frames = int(seconds * fps)
    active_fonts = font_paths or find_font_paths()
    card_path = work_dir / "summary_card.png"
    render_summary_card_png(card_path, summary, active_fonts, width=width, height=height)
    watermark_path = work_dir / f"watermark_tunemyfi_{width}x{height}.png"
    if not watermark_path.exists():
        render_watermark_png(watermark_path, active_fonts, width=width, height=height)

    scale_w = even(int(width * 1.08))
    scale_h = even(int(height * 1.08))
    filter_complex = (
        f"[0:v]fps={fps},"
        f"scale={scale_w}:{scale_h}:force_original_aspect_ratio=increase,"
        f"crop=w={width}:h={height}:x='(iw-ow)/2':y='(ih-oh)/2',"
        "setpts=PTS-STARTPTS,eq=brightness=-0.07:saturation=0.95,format=rgba[base];"
        "[base][1:v]overlay=0:0:shortest=1[tmp1];"
        "[tmp1][2:v]overlay=0:0:shortest=1,format=yuv420p[outv]"
    )

    subprocess.run(
        [
            "ffmpeg",
            "-y",
            "-loop",
            "1",
            "-i",
            str(image_path),
            "-loop",
            "1",
            "-i",
            str(card_path),
            "-loop",
            "1",
            "-i",
            str(watermark_path),
            "-filter_complex",
            filter_complex,
            "-map",
            "[outv]",
            "-t",
            str(seconds),
            "-r",
            str(fps),
            "-an",
            str(clip_path),
        ],
        check=True,
    )


def work_paths(root: Path, product_slug: str, resource_ids: list[str]) -> tuple[str, Path, Path]:
    resource_key = "-".join(resource_ids)
    work_dir = root / "data" / "video-work" / product_slug / f"{resource_key}-qwen-dubbed-ko"
    out_dir = root / "public" / "videos" / product_slug
    work_dir.mkdir(parents=True, exist_ok=True)
    out_dir.mkdir(parents=True, exist_ok=True)
    return resource_key, work_dir, out_dir


def prepare_narration_assets(args, root: Path, resource_ids: list[str], assets: list[dict]) -> dict:
    pronunciation_map = load_pronunciation_map(root)
    resource_key, work_dir, _ = work_paths(root, args.product_slug, resource_ids)
    verdict_text = read_verdict_text(args.verdict_file)

    if args.video_kind == "shorts":
        prompt = build_shorts_prompt(
            product_name=args.product_name,
            target_seconds=args.target_seconds,
            verdict_text=verdict_text,
            resource_ids=resource_ids,
            asset_count=len(assets),
            pronunciation_map=pronunciation_map,
        )
    else:
        prompt = build_prompt(
            product_name=args.product_name,
            target_seconds=args.target_seconds,
            verdict_text=verdict_text,
            resource_ids=resource_ids,
            asset_count=len(assets),
            pronunciation_map=pronunciation_map,
        )

    prefix = "shorts_" if args.video_kind == "shorts" else ""
    prompt_path = work_dir / f"{prefix}prompt.txt"
    prompt_path.write_text(prompt, "utf-8")

    narration = call_ollama(args.model, prompt).strip()
    spoken_narration = make_spoken_script(narration, pronunciation_map)

    narration_path = work_dir / f"{prefix}narration_ko.txt"
    spoken_path = work_dir / f"{prefix}narration_spoken_ko.txt"
    narration_path.write_text(narration, "utf-8")
    spoken_path.write_text(spoken_narration, "utf-8")

    overlay_plan = normalize_overlay_plan({}, len(assets))
    overlay_plan_path = work_dir / f"{prefix}overlay_plan.json"
    if not args.no_overlay:
        overlay_plan = generate_overlay_plan(
            model=args.model,
            product_name=args.product_name,
            verdict_text=verdict_text,
            narration_text=narration,
            scene_count=len(assets),
        )
    overlay_plan_path.write_text(json.dumps(overlay_plan, ensure_ascii=False, indent=2), "utf-8")

    return {
        "ok": True,
        "mode": "prepare-shorts" if args.video_kind == "shorts" else "prepare",
        "videoKind": args.video_kind,
        "productSlug": args.product_slug,
        "resourceIds": resource_ids,
        "resourceKey": resource_key,
        "promptPath": str(prompt_path),
        "narrationPath": str(narration_path),
        "spokenNarrationPath": str(spoken_path),
        "overlayPlanPath": str(overlay_plan_path),
        "narrationText": narration,
        "spokenText": spoken_narration,
        "summaryPreview": overlay_plan.get("summary", {}),
        "assetCount": len(assets),
        "selectedAssetsUsed": bool(load_selected_public_paths(root, args.product_slug)),
        "overlayEnabled": not args.no_overlay,
        "watermarkEnabled": True,
    }


def read_optional_text_file(path_text: str) -> str:
    if not path_text:
        return ""
    path = Path(path_text)
    if not path.exists():
        raise FileNotFoundError(f"text file not found: {path}")
    return path.read_text("utf-8").strip()


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--product-slug", required=True)
    ap.add_argument("--resource-ids", required=True)
    ap.add_argument("--product-name", required=True)
    ap.add_argument("--model", default="qwen3:32b")
    ap.add_argument("--limit", type=int, default=32)
    ap.add_argument("--target-seconds", type=int, default=270)
    ap.add_argument("--verdict-file", default="")
    ap.add_argument("--narration-file", default="")
    ap.add_argument("--spoken-narration-file", default="")
    ap.add_argument("--overlay-plan-file", default="")
    ap.add_argument("--prepare-only", action="store_true")
    ap.add_argument("--no-overlay", action="store_true")
    ap.add_argument("--no-bgm", action="store_true")
    ap.add_argument("--bgm-mood", default="bright", choices=["auto", "bright", "premium", "calm", "tech", "warm"])
    ap.add_argument("--bgm-volume", type=float, default=0.12)
    ap.add_argument("--video-kind", default="long", choices=["long", "shorts"])
    args = ap.parse_args()

    root = resolve_web_root()
    resource_ids = parse_resource_ids(args.resource_ids)

    if not resource_ids:
        raise RuntimeError("resource-ids가 비어 있습니다.")

    assets = pick_assets(root=root, product_slug=args.product_slug, resource_ids=resource_ids, limit=args.limit)

    if not assets:
        raise RuntimeError("assets가 없습니다.")

    resource_key, work_dir, out_dir = work_paths(root, args.product_slug, resource_ids)
    is_shorts = args.video_kind == "shorts"
    video_width = 1080 if is_shorts else 1920
    video_height = 1920 if is_shorts else 1080
    prefix = "shorts_" if is_shorts else ""

    if args.prepare_only:
        result = prepare_narration_assets(args, root, resource_ids, assets)
        print(json.dumps(result, ensure_ascii=False, indent=2))
        unload_ollama_model(args.model)
        return

    pronunciation_map = load_pronunciation_map(root)
    verdict_text = read_verdict_text(args.verdict_file)

    narration = read_optional_text_file(args.narration_file)
    spoken_narration = read_optional_text_file(args.spoken_narration_file)

    if not narration:
        prepared = prepare_narration_assets(args, root, resource_ids, assets)
        narration = prepared["narrationText"]
        spoken_narration = prepared["spokenText"]

    if not spoken_narration:
        spoken_narration = make_spoken_script(narration, pronunciation_map)

    narration_path = work_dir / f"{prefix}narration_ko.txt"
    spoken_path = work_dir / f"{prefix}narration_spoken_ko.txt"
    narration_path.write_text(narration, "utf-8")
    spoken_path.write_text(spoken_narration, "utf-8")

    overlay_plan_path = Path(args.overlay_plan_file) if args.overlay_plan_file else work_dir / f"{prefix}overlay_plan.json"
    if not args.no_overlay and overlay_plan_path.exists():
        overlay_plan = normalize_overlay_plan(json.loads(overlay_plan_path.read_text("utf-8")), len(assets))
    else:
        overlay_plan = normalize_overlay_plan({}, len(assets))
        if not args.no_overlay:
            overlay_plan = generate_overlay_plan(
                model=args.model,
                product_name=args.product_name,
                verdict_text=verdict_text,
                narration_text=narration,
                scene_count=len(assets),
            )
        overlay_plan_path.write_text(json.dumps(overlay_plan, ensure_ascii=False, indent=2), "utf-8")

    audio_path = work_dir / f"{prefix}narration_ko.mp3"
    asyncio.run(make_tts(spoken_narration, audio_path))

    audio_seconds = ffprobe_duration(audio_path)
    summary_seconds = (4.0 if is_shorts else 10.0) if not args.no_overlay else 0.0
    planned_clip_count = len(assets) + (1 if not args.no_overlay else 0)
    transition_count = max(0, planned_clip_count - 1)
    image_target_seconds = audio_seconds + VIDEO_TRANSITION_DURATION * transition_count

    font_paths = find_font_paths() if not args.no_overlay else None
    scene_captions = overlay_plan.get("sceneCaptions", [])
    scene_durations = distribute_scene_durations(
        captions=scene_captions,
        scene_count=len(assets),
        target_total_seconds=image_target_seconds,
    )
    clips = []
    clip_durations: list[float] = []

    for i, asset in enumerate(assets, 1):
        image_path = root / "public" / asset["publicPath"].lstrip("/")
        clip_path = work_dir / f"{prefix}scene_{i:02d}.mp4"

        if not image_path.exists():
            raise FileNotFoundError(f"image not found: {image_path}")
        overlay = None  # captions are overlaid later by narration timeline, not by image cuts

        scene_seconds = scene_durations[i - 1] if i - 1 < len(scene_durations) else max(3.2, image_target_seconds / len(assets))

        render_scene(
            image_path=image_path,
            clip_path=clip_path,
            seconds=scene_seconds,
            overlay=overlay,
            work_dir=work_dir,
            scene_index=i,
            width=video_width,
            height=video_height,
            font_paths=font_paths,
        )

        clips.append(clip_path)
        clip_durations.append(scene_seconds)

    if not args.no_overlay:
        summary_clip_path = work_dir / f"{prefix}scene_summary.mp4"
        summary_image = root / "public" / assets[-1]["publicPath"].lstrip("/")
        render_summary_scene(
            image_path=summary_image,
            clip_path=summary_clip_path,
            seconds=summary_seconds,
            summary=overlay_plan.get("summary", {}),
            work_dir=work_dir,
            width=video_width,
            height=video_height,
            font_paths=font_paths,
        )
        clips.append(summary_clip_path)
        clip_durations.append(summary_seconds)

    clips_txt = work_dir / f"{prefix}clips.txt"
    clips_txt.write_text("".join(f"file '{p.resolve()}'\n" for p in clips), "utf-8")

    silent_path = work_dir / f"{prefix}silent.mp4"
    render_video_with_transitions(
        clips=clips,
        durations=clip_durations,
        out_path=silent_path,
        fps=30,
        transition_duration=VIDEO_TRANSITION_DURATION,
    )

    caption_timeline: list[dict] = []
    video_base_path = silent_path
    if not args.no_overlay and scene_captions and font_paths:
        captioned_silent_path = work_dir / f"{prefix}silent_caption_timeline.mp4"
        caption_timeline = overlay_caption_timeline(
            base_video_path=silent_path,
            out_path=captioned_silent_path,
            captions=scene_captions,
            total_seconds=audio_seconds,
            work_dir=work_dir,
            font_paths=font_paths,
            width=video_width,
            height=video_height,
            fps=30,
        )
        video_base_path = captioned_silent_path

    final_name = f"{resource_key}-qwen-shorts-ko.mp4" if is_shorts else f"{resource_key}-qwen-dubbed-ko.mp4"
    final_path = out_dir / final_name

    bgm_enabled = not args.no_bgm
    bgm_plan = None
    bgm_plan_path = None
    bgm_path = None
    mixed_audio_path = None
    final_audio_duration = audio_seconds + summary_seconds

    if bgm_enabled:
        bgm_plan = generate_bgm_plan(
            model=args.model,
            product_name=args.product_name,
            verdict_text=verdict_text,
            narration_text=narration,
            bgm_mood=args.bgm_mood,
        )
        bgm_plan_path = work_dir / f"{prefix}bgm_plan.json"
        bgm_plan_path.write_text(json.dumps(bgm_plan, ensure_ascii=False, indent=2), "utf-8")

        bgm_path = work_dir / f"{prefix}background_music.wav"
        mixed_audio_path = work_dir / f"{prefix}narration_with_bgm.m4a"
        bgm_volume = max(0.03, min(0.30, float(args.bgm_volume)))

        external_bgm = find_external_bgm_file(root, is_shorts=is_shorts)
        if external_bgm:
            bgm_path = external_bgm
            bgm_plan["source"] = "external"
            bgm_plan["sourcePath"] = str(external_bgm)
            bgm_plan_path.write_text(json.dumps(bgm_plan, ensure_ascii=False, indent=2), "utf-8")
        else:
            bgm_plan["source"] = "generated"
            bgm_plan_path.write_text(json.dumps(bgm_plan, ensure_ascii=False, indent=2), "utf-8")
            generate_background_music_wav(
                out_path=bgm_path,
                duration_seconds=final_audio_duration,
                plan=bgm_plan,
                volume=bgm_volume,
            )

        fade_out_start = max(0.0, final_audio_duration - 5.0)
        subprocess.run(
            [
                "ffmpeg",
                "-y",
                "-i",
                str(audio_path),
                "-i",
                str(bgm_path),
                "-filter_complex",
                (
                    f"[0:a]apad=pad_dur={summary_seconds:.3f},volume=1.0[narr];"
                    f"[1:a]volume=1.0,afade=t=in:st=0:d=3,"
                    f"afade=t=out:st={fade_out_start:.3f}:d=5[bgm];"
                    "[narr][bgm]amix=inputs=2:duration=longest:dropout_transition=2,"
                    "alimiter=limit=0.95[aout]"
                ),
                "-map",
                "[aout]",
                "-c:a",
                "aac",
                "-b:a",
                "192k",
                str(mixed_audio_path),
            ],
            check=True,
        )

        subprocess.run(
            [
                "ffmpeg",
                "-y",
                "-i",
                str(video_base_path),
                "-i",
                str(mixed_audio_path),
                "-c:v",
                "copy",
                "-c:a",
                "aac",
                "-b:a",
                "192k",
                "-shortest",
                str(final_path),
            ],
            check=True,
        )
    else:
        subprocess.run(
            [
                "ffmpeg",
                "-y",
                "-i",
                str(video_base_path),
                "-i",
                str(audio_path),
                "-c:v",
                "copy",
                "-c:a",
                "aac",
                "-b:a",
                "192k",
                "-af",
                "apad",
                "-shortest",
                str(final_path),
            ],
            check=True,
        )

    result = {
        "ok": True,
        "mode": "shorts-video" if is_shorts else "video",
        "videoKind": args.video_kind,
        "productSlug": args.product_slug,
        "resourceIds": resource_ids,
        "filename": final_name,
        "publicPath": f"/videos/{args.product_slug}/{final_name}",
        "narrationPath": str(narration_path),
        "spokenNarrationPath": str(spoken_path),
        "overlayPlanPath": str(overlay_plan_path),
        "audioPath": str(audio_path),
        "bgmEnabled": bgm_enabled,
        "bgmMood": args.bgm_mood if bgm_enabled else None,
        "bgmVolume": bgm_volume if bgm_enabled else None,
        "bgmPath": str(bgm_path) if bgm_path else None,
        "bgmPlanPath": str(bgm_plan_path) if bgm_plan_path else None,
        "bgmPlan": bgm_plan,
        "mixedAudioPath": str(mixed_audio_path) if mixed_audio_path else None,
        "durationSeconds": final_audio_duration,
        "audioDurationSeconds": audio_seconds,
        "summarySeconds": summary_seconds,
        "captionTimingMode": "narration-timeline-independent",
        "captionTimeline": caption_timeline,
        "assetCount": len(assets),
        "selectedAssetsUsed": bool(load_selected_public_paths(root, args.product_slug)),
        "overlayEnabled": not args.no_overlay,
        "watermarkEnabled": True,
        "videoTransitions": TRANSITION_LIBRARY[: max(0, len(clips) - 1)],
        "sceneDurations": clip_durations[: len(assets)],
        "captionTimingMode": "narration-timeline-independent",
        "cardFontTitle": (font_paths or {}).get("title") if not args.no_overlay else None,
        "cardFontBody": (font_paths or {}).get("body") if not args.no_overlay else None,
        "summaryPreview": overlay_plan.get("summary", {}),
        "narrationPreview": narration[:300],
        "spokenPreview": spoken_narration[:300],
    }

    print(json.dumps(result, ensure_ascii=False, indent=2))
    unload_ollama_model(args.model)


if __name__ == "__main__":
    main()
